<Window x:Class="WPFToolGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFToolGame"
        mc:Ignorable="d"
        Title="Vua Pháp Thuật Auto Bot" Height="450" Width="600"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnStart" Content="▶ Bắt đầu (Start)" Width="120" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="btnStart_Click"/>
            <Button x:Name="btnStop" Content="⏹ Dừng (Stop)" Width="120" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" Margin="10,0,0,0" IsEnabled="False" Click="btnStop_Click"/>
            <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Trạng thái Bot:" FontWeight="Bold" Foreground="Gray"/>
                <TextBlock x:Name="txtStatus" Text="Đang nghỉ ngơi" FontWeight="Bold" FontSize="16" Foreground="Blue"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Số Pet đã bắt: " FontWeight="Bold"/>
            <TextBlock x:Name="txtPetCount" Text="0" Foreground="Green" FontWeight="Bold" Margin="0,0,20,0"/>
            <TextBlock Text="Trận đã đánh: " FontWeight="Bold"/>
            <TextBlock x:Name="txtBattleCount" Text="0" Foreground="Red" FontWeight="Bold"/>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="Nhật ký hoạt động (Logs)">
            <ListBox x:Name="lbLogs" Background="#1E1E1E" Foreground="#00FF00" FontFamily="Consolas"/>
        </GroupBox>
    </Grid>
</Window>
